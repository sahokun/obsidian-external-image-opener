{
  "name": "obsidian-external-image-opener",
  "version": "1.0.0",
  "author": "sahokun",
  "description": "Open images in external programs with keyboard shortcuts or button clicks",
  "main": "dist/main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "bump": "node scripts/version.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "image"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.10",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
